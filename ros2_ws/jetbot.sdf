<?xml version="1.0" ?>
<sdf version="1.8">
    <world name="car_world">
        <physics name="1ms" type="ignored">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1.0</real_time_factor>
        </physics>
        <plugin
            filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics">
        </plugin>
        <plugin
            filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands">
        </plugin>
        <plugin
            filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster">
        </plugin>
        <plugin
            filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>

        <light type="directional" name="sun">
            <cast_shadows>true</cast_shadows>
            <pose>0 0 10 0 0 0</pose>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
            <attenuation>
                <range>1000</range>
                <constant>0.9</constant>
                <linear>0.01</linear>
                <quadratic>0.001</quadratic>
            </attenuation>
            <direction>-0.5 0.1 -0.9</direction>
        </light>

        <model name="ground_plane">
            <static>true</static>
            <link name="link">
                <collision name="collision">
                <geometry>
                    <plane>
                    <normal>0 0 1</normal>
                    </plane>
                </geometry>
                </collision>
                <visual name="visual">
                <geometry>
                    <plane>
                    <normal>0 0 1</normal>
                    <size>24 18</size>
                    </plane>
                </geometry>
                <material>
                    <ambient>0.8 0.8 0.8 1</ambient>
                    <diffuse>0.8 0.8 0.8 1</diffuse>
                    <specular>0.8 0.8 0.8 1</specular>
                </material>
                </visual>
            </link>
        </model>

        <model name='jetbot1' canonical_link='chassis'>
            <pose relative_to='world'>0 -3 0 0 0 0</pose>   <!--the pose is relative to the world by default-->

            <!-- sensor frames -->
            <frame name="lidar_frame" attached_to='chassis'>
                <pose>0.0 0.0 1.0 0 0 0</pose>
            </frame>

            <frame name="camera_frame" attached_to='chassis'>
                <pose>0.0 0.0 1.0 0 0 0</pose>
            </frame>

            <!--chassis-->
            <link name='chassis'>
                <pose relative_to='__model__'>0.0 0 0.45 0 0 0</pose>
                <inertial> <!--inertial properties of the link mass, inertia matix-->
                    <mass>1.14395</mass>
                    <inertia>
                        <ixx>0.095329</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.381317</iyy>
                        <iyz>0</iyz>
                        <izz>0.476646</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>1.07</radius>
                            <length>0.1</length>
                        </cylinder>
                    </geometry>
                    <!--Color of the link-->
                    <material>
                        <ambient>0.6 0.8 0.4 1</ambient>
                        <diffuse>0.6 0.8 0.4 1</diffuse>
                        <specular>0.6 0.8 0.4 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.107</radius>
                            <length>0.01</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!-- LIDAR 3D shape definition -->
            <link name='lidar1'>
                <pose relative_to='chassis'>0.0 0 0.4 0 0 0</pose>
                <inertial> <!--inertial properties of the link mass, inertia matix-->
                    <mass>1.14395</mass>
                    <inertia>
                        <ixx>0.095329</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.381317</iyy>
                        <iyz>0</iyz>
                        <izz>0.476646</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.8</length>
                        </cylinder>
                    </geometry>
                    <!--Color of the link-->
                    <material>
                        <ambient>0.0 0.0 0.0 1</ambient>
                        <diffuse>0.0 0.0 0.0 1</diffuse>
                        <specular>0.0 0.0 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.8</length>
                        </cylinder>
                    </geometry>
                </collision>
    
                <!-- LIDAR sensor parameters -->
                <sensor name='gpu_lidar' type='gpu_lidar'>"
                    <pose relative_to='lidar_frame'>0 0 0 0 0 0</pose>
                    <topic>/J1/lidar</topic>
                    <update_rate>5</update_rate>
                    <ray>
                        <scan>
                            <horizontal>
                                <samples>360</samples>
                                <resolution>1</resolution>
                                <min_angle>-1.396263</min_angle>
                                <max_angle>1.396263</max_angle>
                            </horizontal>
                            <vertical>
                                <samples>1</samples>
                                <resolution>0.01</resolution>
                                <min_angle>0</min_angle>
                                <max_angle>0</max_angle>
                            </vertical>
                        </scan>
                        <range>
                            <min>0.15</min>
                            <max>12.0</max>
                            <resolution>0.01</resolution>
                        </range>
                    </ray>
                    <always_on>1</always_on>
                    <visualize>true</visualize>
                </sensor>                
            </link>

            <!-- CAMERA 3D shape definition -->
            <link name='camera1'>
                <pose relative_to='chassis'>0.8 0.0 0.3 0 0 0</pose>
                <inertial> <!--inertial properties of the link mass, inertia matix-->
                    <mass>0.1</mass>
                    <inertia>
                        <ixx>0.095329</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.381317</iyy>
                        <iyz>0</iyz>
                        <izz>0.476646</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <box>
                            <size>0.1 0.3 0.6</size>
                        </box>
                    </geometry>
                    <!--Color of the link-->
                    <material>
                        <ambient>0.6 0.9 0.4 1</ambient>
                        <diffuse>0.6 0.9 0.4 1</diffuse>
                        <specular>0.6 0.9 0.4 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.8</length>
                        </cylinder>
                    </geometry>
                </collision>

                <!-- CAMERA sensor parameters -->
                <sensor name="rgb_camera" type="camera">
                    <pose relative_to='camera_frame'>0 0 0 0 0 0</pose>
                    <always_on>true</always_on>
                    <visualize>true</visualize>
                    <update_rate>5</update_rate>
                    <topic>/J1/camera/image_raw</topic>
                    <gz_frame_id>camera_rgb_frame</gz_frame_id>
                    <camera name="intel_realsense_r200">
                        <camera_info_topic>/J1/camera/camera_info</camera_info_topic>
                        <horizontal_fov>1.02974</horizontal_fov>
                        <image>
                            <width>320</width>
                            <height>240</height>
                            <format>R8G8B8</format>
                        </image>
                        <clip>
                            <near>0.02</near>
                            <far>300</far>
                        </clip>
                    </camera>
                </sensor>
            </link>

            <!--Left wheel 3D shape definition-->
            <link name='left_wheel'>
                <pose relative_to="chassis">0.0 1.17 0 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.0 0.0 0.0 1</ambient>
                        <diffuse>0.0 0.0 0.0 1</diffuse>
                        <specular>0.0 0.0 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!--Right wheel 3D shape definition-->
            <link name='right_wheel'>
                <pose relative_to="chassis">0.0 -1.17 0 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.0 0.0 0.0 1</ambient>
                        <diffuse>0.0 0.0 0.0 1</diffuse>
                        <specular>0.0 0.0 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!--arbitrary frame-->
            <frame name="caster_frame0" attached_to='chassis'>
                <pose>0.8 0 -0.2 0 0 0</pose>
            </frame>

            <!--caster wheel-->
            <link name='caster0'>
                <pose relative_to='caster_frame0'/>
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.016</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.016</iyy>
                        <iyz>0</iyz>
                        <izz>0.016</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                    <material>
                        <ambient>0.4 0.4 0.4 1</ambient>
                        <diffuse>0.4 0.4 0.4 1</diffuse>
                        <specular>0.4 0.4 0.4 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                </collision>
            </link>

            <!--arbitrary frame-->
            <frame name="caster_frame1" attached_to='chassis'>
                <pose>-0.8 0 -0.2 0 0 0</pose>
            </frame>

            <!--caster wheel-->
            <link name='caster1'>
                <pose relative_to='caster_frame1'/>
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.016</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.016</iyy>
                        <iyz>0</iyz>
                        <izz>0.016</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                    <material>
                        <ambient>0.4 0.4 0.4 1</ambient>
                        <diffuse>0.4 0.4 0.4 1</diffuse>
                        <specular>0.4 0.4 0.4 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                </collision>
            </link>

            <!--left wheel joint-->
            <joint name='left_wheel_joint' type='revolute'>
                <pose relative_to='left_wheel'/>
                <parent>chassis</parent>
                <child>left_wheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz> <!--can be descired to any frame or even arbitrary frames-->
                    <limit>
                        <lower>-1.79769e+308</lower>    <!--negative infinity-->
                        <upper>1.79769e+308</upper>     <!--positive infinity-->
                    </limit>
                </axis>
            </joint>

            <!--right wheel joint-->
            <joint name='right_wheel_joint' type='revolute'>
                <pose relative_to='right_wheel'/>
                <parent>chassis</parent>
                <child>right_wheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz>
                    <limit>
                        <lower>-1.79769e+308</lower>    <!--negative infinity-->
                        <upper>1.79769e+308</upper>     <!--positive infinity-->
                    </limit>
                </axis>
            </joint>

            <!--caster wheel joint--> <!--pose defult value is the child-->
            <joint name='caster_wheel_front' type='ball'>
                <parent>chassis</parent>
                <child>caster0</child>
            </joint>
            <joint name='caster_wheel_rear' type='ball'>
                <parent>chassis</parent>
                <child>caster1</child>
            </joint>

            <joint name="lidar_joint" type="fixed">
                <parent>chassis</parent>
                <child>lidar1</child>
            </joint>

            <joint name="camera_joint" type="fixed">
                <parent>chassis</parent>
                <child>camera1</child>
            </joint>
            
            <!-- cmd_vel and odometry -->
            <plugin
                filename="gz-sim-diff-drive-system"
                name="gz::sim::systems::DiffDrive">
                <left_joint>left_wheel_joint</left_joint>
                <right_joint>right_wheel_joint</right_joint>
                <wheel_separation>1.2</wheel_separation>
                <wheel_radius>0.4</wheel_radius>
                <odom_publish_frequency>1</odom_publish_frequency>
                <topic>/J1/cmd_vel</topic>
                <odom_topic>/J1/odom</odom_topic>
                <tf_topic>/J1/tf</tf_topic>
            </plugin>

        </model>

        <model name='jetbot2' canonical_link='chassis'>
            <pose relative_to='world'>0 3 0 0 0 0</pose>   <!--the pose is relative to the world by default-->

            <!-- sensor frames -->
            <frame name="lidar_frame" attached_to='chassis'>
                <pose>0.0 0.0 1.0 0 0 0</pose>
            </frame>

            <frame name="camera_frame" attached_to='chassis'>
                <pose>0.0 0.0 1.0 0 0 0</pose>
            </frame>

            <!--chassis-->
            <link name='chassis'>
                <pose relative_to='__model__'>0.0 0 0.45 0 0 0</pose>
                <inertial> <!--inertial properties of the link mass, inertia matix-->
                    <mass>1.14395</mass>
                    <inertia>
                        <ixx>0.095329</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.381317</iyy>
                        <iyz>0</iyz>
                        <izz>0.476646</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>1.07</radius>
                            <length>0.1</length>
                        </cylinder>
                    </geometry>
                    <!--Color of the link-->
                    <material>
                        <ambient>0.6 0.8 0.4 1</ambient>
                        <diffuse>0.6 0.8 0.4 1</diffuse>
                        <specular>0.6 0.8 0.4 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.107</radius>
                            <length>0.01</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!-- LIDAR 3D shape definition -->
            <link name='lidar2'>
                <pose relative_to='chassis'>0.0 0 0.4 0 0 0</pose>
                <inertial> <!--inertial properties of the link mass, inertia matix-->
                    <mass>1.14395</mass>
                    <inertia>
                        <ixx>0.095329</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.381317</iyy>
                        <iyz>0</iyz>
                        <izz>0.476646</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.8</length>
                        </cylinder>
                    </geometry>
                    <!--Color of the link-->
                    <material>
                        <ambient>0.0 0.0 0.0 1</ambient>
                        <diffuse>0.0 0.0 0.0 1</diffuse>
                        <specular>0.0 0.0 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.8</length>
                        </cylinder>
                    </geometry>
                </collision>
    
                <!-- LIDAR sensor parameters -->
                <sensor name='gpu_lidar' type='gpu_lidar'>"
                    <pose relative_to='lidar_frame'>0 0 0 0 0 0</pose>
                    <topic>/J2/lidar</topic>
                    <update_rate>5</update_rate>
                    <ray>
                        <scan>
                            <horizontal>
                                <samples>360</samples>
                                <resolution>1</resolution>
                                <min_angle>-1.396263</min_angle>
                                <max_angle>1.396263</max_angle>
                            </horizontal>
                            <vertical>
                                <samples>1</samples>
                                <resolution>0.01</resolution>
                                <min_angle>0</min_angle>
                                <max_angle>0</max_angle>
                            </vertical>
                        </scan>
                        <range>
                            <min>0.15</min>
                            <max>12.0</max>
                            <resolution>0.01</resolution>
                        </range>
                    </ray>
                    <always_on>1</always_on>
                    <visualize>true</visualize>
                </sensor>                
            </link>

            <!-- CAMERA 3D shape definition -->
            <link name='camera2'>
                <pose relative_to='chassis'>0.8 0.0 0.3 0 0 0</pose>
                <inertial> <!--inertial properties of the link mass, inertia matix-->
                    <mass>0.1</mass>
                    <inertia>
                        <ixx>0.095329</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.381317</iyy>
                        <iyz>0</iyz>
                        <izz>0.476646</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <box>
                            <size>0.1 0.3 0.6</size>
                        </box>
                    </geometry>
                    <!--Color of the link-->
                    <material>
                        <ambient>0.6 0.9 0.4 1</ambient>
                        <diffuse>0.6 0.9 0.4 1</diffuse>
                        <specular>0.6 0.9 0.4 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.8</length>
                        </cylinder>
                    </geometry>
                </collision>

                <!-- CAMERA sensor parameters -->
                <sensor name="rgb_camera" type="camera">
                    <pose relative_to='camera_frame'>0 0 0 0 0 0</pose>
                    <always_on>true</always_on>
                    <visualize>true</visualize>
                    <update_rate>5</update_rate>
                    <topic>/J2/camera/image_raw</topic>
                    <gz_frame_id>camera_rgb_frame</gz_frame_id>
                    <camera name="intel_realsense_r200">
                        <camera_info_topic>/J2/camera/camera_info</camera_info_topic>
                        <horizontal_fov>1.02974</horizontal_fov>
                        <image>
                            <width>320</width>
                            <height>240</height>
                            <format>R8G8B8</format>
                        </image>
                        <clip>
                            <near>0.02</near>
                            <far>300</far>
                        </clip>
                    </camera>
                </sensor>
            </link>

            <!--Left wheel 3D shape definition-->
            <link name='left_wheel'>
                <pose relative_to="chassis">0.0 1.17 0 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.0 0.0 0.0 1</ambient>
                        <diffuse>0.0 0.0 0.0 1</diffuse>
                        <specular>0.0 0.0 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!--Right wheel 3D shape definition-->
            <link name='right_wheel'>
                <pose relative_to="chassis">0.0 -1.17 0 -1.5707 0 0</pose> <!--angles are in radian-->
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.0 0.0 0.0 1</ambient>
                        <diffuse>0.0 0.0 0.0 1</diffuse>
                        <specular>0.0 0.0 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>

            <!--arbitrary frame-->
            <frame name="caster_frame0" attached_to='chassis'>
                <pose>0.8 0 -0.2 0 0 0</pose>
            </frame>

            <!--caster wheel-->
            <link name='caster0'>
                <pose relative_to='caster_frame0'/>
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.016</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.016</iyy>
                        <iyz>0</iyz>
                        <izz>0.016</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                    <material>
                        <ambient>0.4 0.4 0.4 1</ambient>
                        <diffuse>0.4 0.4 0.4 1</diffuse>
                        <specular>0.4 0.4 0.4 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                </collision>
            </link>

            <!--arbitrary frame-->
            <frame name="caster_frame1" attached_to='chassis'>
                <pose>-0.8 0 -0.2 0 0 0</pose>
            </frame>

            <!--caster wheel-->
            <link name='caster1'>
                <pose relative_to='caster_frame1'/>
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.016</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.016</iyy>
                        <iyz>0</iyz>
                        <izz>0.016</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                    <material>
                        <ambient>0.4 0.4 0.4 1</ambient>
                        <diffuse>0.4 0.4 0.4 1</diffuse>
                        <specular>0.4 0.4 0.4 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                </collision>
            </link>

            <!--left wheel joint-->
            <joint name='left_wheel_joint' type='revolute'>
                <pose relative_to='left_wheel'/>
                <parent>chassis</parent>
                <child>left_wheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz> <!--can be descired to any frame or even arbitrary frames-->
                    <limit>
                        <lower>-1.79769e+308</lower>    <!--negative infinity-->
                        <upper>1.79769e+308</upper>     <!--positive infinity-->
                    </limit>
                </axis>
            </joint>

            <!--right wheel joint-->
            <joint name='right_wheel_joint' type='revolute'>
                <pose relative_to='right_wheel'/>
                <parent>chassis</parent>
                <child>right_wheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz>
                    <limit>
                        <lower>-1.79769e+308</lower>    <!--negative infinity-->
                        <upper>1.79769e+308</upper>     <!--positive infinity-->
                    </limit>
                </axis>
            </joint>

            <!--caster wheel joint--> <!--pose defult value is the child-->
            <joint name='caster_wheel_front' type='ball'>
                <parent>chassis</parent>
                <child>caster0</child>
            </joint>
            <joint name='caster_wheel_rear' type='ball'>
                <parent>chassis</parent>
                <child>caster1</child>
            </joint>

            <joint name="lidar_joint" type="fixed">
                <parent>chassis</parent>
                <child>lidar2</child>
            </joint>

            <joint name="camera_joint" type="fixed">
                <parent>chassis</parent>
                <child>camera2</child>
            </joint>
            
            <!-- cmd_vel and odometry -->
            <plugin
                filename="gz-sim-diff-drive-system"
                name="gz::sim::systems::DiffDrive">
                <left_joint>left_wheel_joint</left_joint>
                <right_joint>right_wheel_joint</right_joint>
                <wheel_separation>1.2</wheel_separation>
                <wheel_radius>0.4</wheel_radius>
                <odom_publish_frequency>1</odom_publish_frequency>
                <topic>/J2/cmd_vel</topic>
                <odom_topic>/J2/odom</odom_topic> 
                <tf_topic>/J2/tf</tf_topic>
            </plugin>

        </model>

        <model name='box_obstacle'>
            <pose relative_to='world'>9 0 3 0 0 0.785</pose> <link name='box_link'>
                <inertial>
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.166667</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.166667</iyy>
                    <iyz>0</iyz>
                    <izz>0.166667</izz>
                </inertia>
                </inertial>
                <collision name='collision'>
                <geometry>
                    <box>
                    <size>2 2 6</size> </box>
                </geometry>
                </collision>
                <visual name='visual'>
                <geometry>
                    <box>
                    <size>2 2 6</size>
                    </box>
                </geometry>
                <material>
                    <ambient>1 0 0 1</ambient> <diffuse>1 0 0 1</diffuse>
                    <specular>0.1 0.1 0.1 1</specular>
                </material>
                </visual>
            </link>
        </model>

    </world>
</sdf>
